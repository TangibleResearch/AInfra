import ai.remote.openai

model cloud {
    engine = "openai"
    name = "gpt-4.1-mini"
    max_output_tokens = 128
    temperature = 0.7
}

prompt answer {
    text = "Answer clearly and briefly: {input}"
}

agent helper {
    model = cloud
    prompt = answer
}

run agent helper on "What is A2VM?"
